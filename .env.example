NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public base URL used to build join links / QR codes and invite redirects.
# Local: http://localhost:3000. In production set this to your real domain, e.g.
# https://saasgymmanagement.vercel.app (on Vercel it auto-falls back to your
# project's production domain if unset, but setting it explicitly is canonical).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# SMTP for password-reset emails (Nodemailer). Use any SMTP host — e.g. Gmail with
# an app password, or a transactional provider. Port 465 = implicit TLS, 587 = STARTTLS.
# Without these, the forgot-password flow still runs but no email is sent.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=you@gmail.com

# WhatsApp number (international format, digits only — e.g. 919812345678) for the
# "Renew on WhatsApp" button on the gym-owner plan-expiry banner. If unset, the
# banner still shows but without the button.
NEXT_PUBLIC_SUPPORT_WHATSAPP=919812345678

# Email invoices via Resend (optional). Without RESEND_API_KEY the Email button
# returns a friendly "not configured" message; everything else keeps working.
RESEND_API_KEY=your-resend-api-key
# Must be an address on a domain you've verified in Resend. Until then, Resend's
# onboarding@resend.dev sender only delivers to your own account email.
RESEND_FROM_EMAIL=invoices@yourgym.com
