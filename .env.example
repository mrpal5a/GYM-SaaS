NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Email invoices via Resend (optional). Without RESEND_API_KEY the Email button
# returns a friendly "not configured" message; everything else keeps working.
RESEND_API_KEY=your-resend-api-key
# Must be an address on a domain you've verified in Resend. Until then, Resend's
# onboarding@resend.dev sender only delivers to your own account email.
RESEND_FROM_EMAIL=invoices@yourgym.com
